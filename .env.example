# Supabase Configuration
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Email Configuration (Gmail App Password)
# Note: DO NOT use your real Gmail password. You must generate an "App Password" 
# at https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=YOUR_GMAIL_APP_PASSWORD_HERE

# DigiCamControl Path (Windows)
DIGICAM_PATH=C:\Program Files (x86)\digiCamControl\CameraControlCmd.exe

# App Configuration
TEMP_FOLDER=./temp

# Google Cloud Storage Configuration
# Name of your service account key file in the root folder
GCS_KEY_PATH=google-key.json